---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Stefanias Cafè – Ein Stück Italia in Erlangen" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Stefanias Cafè – Authentische italienische Küche mit Herz, mitten in Erlangen." />
    <link rel="icon" href="/images/Logo_Stefanias_cafe.png" type="image/png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
