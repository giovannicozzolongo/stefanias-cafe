---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Stefania's Cafè — Erlangen",
  description = "Authentische italienische Küche in Erlangen. Frühstück, Mittagessen und mehr — hausgemacht mit neapolitanischer Leidenschaft.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>

