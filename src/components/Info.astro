---
const hours = [
  { day: "Montag", time: "Geschlossen" },
  { day: "Dienstag", time: "09:00 – 17:00" },
  { day: "Mittwoch", time: "09:00 – 17:00" },
  { day: "Donnerstag", time: "09:00 – 17:00" },
  { day: "Freitag", time: "09:00 – 17:00" },
  { day: "Samstag", time: "09:00 – 18:00" },
  { day: "Sonntag", time: "09:00 – 18:00" },
];

const services = [
  "Barrierefrei",
  "Büfett",
  "Außenbereich",
  "Private Veranstaltungen",
  "Essen zum Mitnehmen",
  "Hochzeiten",
  "Kostenloses WLAN",
  "Haustiere erlaubt",
];

const payments = [
  "Barzahlung",
  "EC-Karte",
  "Kontaktloses Bezahlen",
  "MasterCard",
  "VISA",
  "Überweisung",
];
---

<section class="info" id="hours">
  <div class="container info-grid">
    <div class="info-col">
      <p class="section-label">Öffnungszeiten</p>
      <h2 class="section-title" style="font-size: 1.75rem">Wann wir <em>da sind</em></h2>
      <ul class="hours-list">
        {hours.map(h => (
          <li class={`hours-item ${h.time === 'Geschlossen' ? 'closed' : ''}`}>
            <span class="hours-day">{h.day}</span>
            <span class="hours-time">{h.time}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="info-col">
      <p class="section-label">Services</p>
      <h2 class="section-title" style="font-size: 1.75rem">Was wir <em>anbieten</em></h2>
      <ul class="services-list">
        {services.map(s => (
          <li class="services-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8l3.5 3.5L13 4" stroke="#895a45" stroke-width="2" stroke-linecap="round"/>
            </svg>
            {s}
          </li>
        ))}
      </ul>
    </div>

    <div class="info-col">
      <p class="section-label">Zahlung</p>
      <h2 class="section-title" style="font-size: 1.75rem">Wie ihr <em>zahlt</em></h2>
      <ul class="services-list">
        {payments.map(p => (
          <li class="services-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8l3.5 3.5L13 4" stroke="#895a45" stroke-width="2" stroke-linecap="round"/>
            </svg>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .info {
    padding: var(--section-pad);
    background: var(--color-dark);
    color: var(--color-primary);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem;
  }

  .info .section-label {
    color: rgba(255, 244, 240, 0.5);
  }

  .info .section-title {
    color: var(--color-primary);
  }

  .info .section-title em {
    color: #f0c9b4;
  }

  .hours-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hours-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 244, 240, 0.1);
    font-size: 0.9rem;
  }

  .hours-item.closed .hours-time {
    color: rgba(255, 244, 240, 0.3);
    font-style: italic;
  }

  .hours-day {
    color: rgba(255, 244, 240, 0.7);
  }

  .hours-time {
    color: var(--color-primary);
    font-weight: 600;
  }

  .services-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .services-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(255, 244, 240, 0.85);
  }

  .services-item svg {
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .info-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 540px) {
    .info-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
