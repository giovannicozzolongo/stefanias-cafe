---
const hours = [
  { day: "Montag",     time: "Geschlossen", closed: true },
  { day: "Dienstag",   time: "09:00 – 17:00" },
  { day: "Mittwoch",   time: "09:00 – 17:00" },
  { day: "Donnerstag", time: "09:00 – 17:00" },
  { day: "Freitag",   time: "09:00 – 17:00" },
  { day: "Samstag",   time: "09:00 – 18:00" },
  { day: "Sonntag",   time: "09:00 – 18:00" },
];

const services = [
  "Frühstück & Brunch",
  "Mittagessen",
  "Aperitivo",
  "Essen zum Mitnehmen",
  "Private Veranstaltungen",
  "Catering",
  "Kostenloses WLAN",
  "Außenbereich",
  "Haustiere erlaubt",
];
---
<section class="info" id="orari">
  <div class="container info-grid">
    <div class="info-col">
      <h3 class="info-title">Dienstleistungen</h3>
      <ul class="services-list">
        {services.map(s => (
          <li class="service-item">
            <span class="check">✓</span> {s}
          </li>
        ))}
      </ul>
    </div>

    <div class="info-divider"></div>

    <div class="info-col">
      <h3 class="info-title">Öffnungszeiten</h3>
      <ul class="hours-list">
        {hours.map(h => (
          <li class:list={["hours-item", { closed: h.closed }]}>
            <span class="day">{h.day}</span>
            <span class="time">{h.time}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .info {
    background: var(--c-white);
    padding: var(--pad-section);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .info-divider {
    background: var(--c-border);
    height: 100%;
    min-height: 200px;
  }

  .info-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 1.5rem;
  }

  .services-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-item {
    font-size: 0.875rem;
    color: var(--c-muted);
    display: flex;
    gap: 0.6rem;
  }

  .check {
    color: var(--c-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .hours-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .hours-item {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--c-border);
    font-size: 0.875rem;
  }

  .hours-item:last-child { border-bottom: none; }

  .day { color: var(--c-text); }

  .time { color: var(--c-text); font-weight: 700; }

  .closed .day,
  .closed .time { color: rgba(74,52,51,0.4); font-weight: 400; }

  @media (max-width: 720px) {
    .info-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .info-divider { display: none; }
  }
</style>
