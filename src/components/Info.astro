---
const hours = [
  { day: "Montag",     time: "Geschlossen", closed: true },
  { day: "Dienstag",   time: "09:00 – 17:00" },
  { day: "Mittwoch",   time: "09:00 – 17:00" },
  { day: "Donnerstag", time: "09:00 – 17:00" },
  { day: "Freitag",    time: "09:00 – 17:00" },
  { day: "Samstag",    time: "09:00 – 18:00" },
  { day: "Sonntag",    time: "09:00 – 18:00" },
];

const services = [
  "Buffet",
  "Außenbereich",
  "Hochzeiten",
  "Table Away",
];
---
<section class="info" id="orari">
  <div class="container info-grid">
    <div class="info-col">
      <h3 class="info-title">Dienstleistungen</h3>
      <ul class="services-list">
        {services.map(s => (
          <li class="service-item"><span class="check">✓</span> {s}</li>
        ))}
      </ul>
    </div>

    <div class="info-divider"></div>

    <div class="info-col">
      <h3 class="info-title">Öffnungszeiten</h3>
      <ul class="hours-list">
        {hours.map(h => (
          <li class:list={["hours-item", { closed: h.closed }]}>
            <span class="day">{h.day}</span>
            <span class="time">{h.time}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="info-cta container">
    <h3 class="cta-heading">Besuche unser Café heute!</h3>
    <p class="cta-sub">Folge uns auf Social Media</p>
    <div class="social-links">
      <a href="https://www.facebook.com" target="_blank" rel="noopener" aria-label="Facebook">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
      </a>
      <a href="https://instagram.com/stefanias_cafe" target="_blank" rel="noopener" aria-label="Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .info {
    background: var(--c-white);
    padding: 5rem 0 3rem;
    border-top: 1px solid var(--c-border);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .info-divider {
    background: var(--c-border);
    height: 100%;
    min-height: 180px;
  }

  .info-title {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-orange);
    margin-bottom: 1.25rem;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-item {
    font-size: 0.875rem;
    color: var(--c-muted);
    display: flex;
    gap: 0.6rem;
  }

  .check { color: var(--c-orange); font-weight: 700; }

  .hours-list { display: flex; flex-direction: column; }

  .hours-item {
    display: flex;
    justify-content: space-between;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--c-border);
    font-size: 0.875rem;
  }

  .hours-item:last-child { border-bottom: none; }
  .day { color: var(--c-text); }
  .time { color: var(--c-text); font-weight: 600; }
  .closed .day, .closed .time { color: rgba(0,0,0,0.3); font-weight: 400; }

  /* CTA */
  .info-cta {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border);
  }

  .cta-heading {
    font-family: var(--font-brand);
    font-size: 2rem;
    color: var(--c-dark);
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 1.25rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .social-links a {
    color: var(--c-dark);
    transition: color 0.15s;
  }
  .social-links a:hover { color: var(--c-orange); }

  @media (max-width: 720px) {
    .info-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .info-divider { display: none; }
  }
</style>
