---
const services = [
  'Buffet',
  'Außentische',
  'Private Events',
  'Hochzeiten',
  'Take away',
];
---

<section class="bg-cream py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-16">

      <!-- Services list -->
      <div>
        <h2 class="font-garet font-bold text-brown-dark text-4xl md:text-5xl mb-10">
          Dienstleistungen
        </h2>

        <ul class="flex flex-col gap-3 mb-12">
          {services.map(s => (
            <li class="font-garet text-brown-dark text-xl md:text-2xl flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-terracotta shrink-0 mt-1"></span>
              {s}
            </li>
          ))}
        </ul>

        <a
          href="#reservation"
          class="inline-block font-sauce font-bold text-brown-dark text-2xl md:text-3xl hover:text-terracotta transition-colors duration-200"
        >
          Besuche unser Café heute!
        </a>
      </div>

      <!-- Photo -->
      <div class="overflow-hidden">
        <img
          src="/images/Media_outdoor_cafe.png"
          alt="Außenbereich Stefanias Cafè"
          class="w-full h-full object-cover max-h-96 md:max-h-full"
        />
      </div>

    </div>
  </div>
</section>
