---
---
<section class="hero" id="hero">
  <div class="hero-left">
    <div class="hero-text">
      <p class="hero-eyebrow">Erlangen, Deutschland</p>
      <h1 class="hero-title">Stefania's<br/>Cafè</h1>
      <p class="hero-sub">
        Dal cuore di Napoli fino a Erlangen.<br/>
        Frühstück, pranzo e aperitivo — fatto in casa.
      </p>
      <a href="#reservation" class="btn btn-cream">Reservierung anfragen</a>
    </div>
  </div>

  <div class="hero-right">
    <img src="/stefanias-cafe/img/menu-piatti.jpg" alt="Piatti di Stefania's Cafè" />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    padding-top: 56px;
  }

  .hero-left {
    background: var(--c-black);
    display: flex;
    align-items: center;
    padding: 5rem 4rem 5rem calc((100vw - var(--max-w)) / 2 + var(--pad-x));
  }

  .hero-text { max-width: 420px; }

  .hero-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(245, 236, 215, 0.55);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-family: var(--font-brand);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    color: var(--c-cream);
    line-height: 1.0;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 0.95rem;
    color: rgba(245, 236, 215, 0.75);
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .hero-right {
    position: relative;
    overflow: hidden;
  }

  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-left {
      padding: 4rem 1.5rem;
      justify-content: center;
    }
    .hero-text { max-width: 100%; text-align: center; }
    .hero-right { height: 60vw; }
  }
</style>
