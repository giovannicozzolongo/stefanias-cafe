---
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/stefanias-cafe/img/hero-bg.png" alt="" />
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <p class="hero-eyebrow">Ein Stück Italia — mitten in Erlangen</p>
    <h1 class="hero-title">Stefanias<br/>Cafè</h1>
    <p class="hero-sub">Ein Stück Italia — mit Herz serviert.</p>
    <a href="#menu" class="btn btn-dark hero-btn">See our menu &rarr;</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(18, 12, 8, 0.72);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 70px;
    max-width: 680px;
  }

  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-family: var(--font-brand);
    font-size: clamp(4rem, 9vw, 7rem);
    color: #fff;
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
  }

  .hero-btn {
    font-size: 0.8rem;
    padding: 0.85rem 2rem;
    background: var(--c-dark);
    color: #fff;
    border: none;
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .hero-content { padding-top: 90px; }
    .hero-title { font-size: 3.5rem; }
  }
</style>
