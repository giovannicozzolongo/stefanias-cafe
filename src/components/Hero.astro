---
import Navbar from './Navbar.astro';
---

<section id="home" class="relative min-h-screen flex flex-col md:flex-row">
  <!-- Left: food photo -->
  <div class="relative w-full md:w-1/2 min-h-[50vh] md:min-h-screen overflow-hidden">
    <img
      src="/images/Bg_colazione.png"
      alt="Cucina di Stefanias Cafè"
      class="w-full h-full object-cover absolute inset-0"
    />
    <!-- Text overlay on image -->
    <div class="relative z-10 flex flex-col justify-center h-full px-10 md:px-14 py-24">
      <p class="font-sauce font-bold text-white text-3xl md:text-4xl lg:text-5xl leading-tight max-w-xs">
        Have a sip, feel Napoli's warmth in Erlangen!
      </p>
    </div>
  </div>

  <!-- Right: dark bg -->
  <div class="relative w-full md:w-1/2 bg-dark flex flex-col min-h-[50vh] md:min-h-screen">
    <!-- Navbar sits at top of dark half -->
    <div class="relative z-20">
      <Navbar />
    </div>

    <!-- Content centered vertically -->
    <div class="flex flex-col justify-center flex-1 px-10 md:px-14 pb-16">
      <h1 class="font-sauce font-bold text-white leading-none text-7xl md:text-8xl lg:text-9xl mb-6">
        Stefanias<br />Cafè
      </h1>
      <p class="font-sauce text-white text-lg md:text-2xl mb-10 opacity-90">
        Ein Stück Italia – mit Herz serviert.
      </p>
      <a
        href="#menu"
        class="inline-block bg-white text-dark font-sauce font-bold text-base md:text-lg px-10 py-4 self-start hover:bg-cream transition-colors duration-200"
      >
        See our menu
      </a>
    </div>
  </div>
</section>

<!-- Second hero strip -->
<section class="relative min-h-[40vh] md:min-h-[60vh] flex flex-col md:flex-row bg-dark">
  <!-- Left text area -->
  <div class="w-full md:w-1/2 flex items-center px-10 md:px-14 py-16">
    <p class="font-sauce font-bold text-white text-2xl md:text-4xl lg:text-5xl leading-snug max-w-sm">
      Probiert die echte Napoli in Erlangen!
    </p>
  </div>
  <!-- Right: photo -->
  <div class="relative w-full md:w-1/2 min-h-[30vh] md:min-h-[60vh] overflow-hidden">
    <img
      src="/images/Cover_Bresaola.png"
      alt="Bresaola con Rucola"
      class="w-full h-full object-cover absolute inset-0"
    />
    <!-- "Stefanias Cafè" overlay -->
    <div class="relative z-10 flex flex-col justify-center h-full px-10 md:px-14 py-16">
      <h2 class="font-sauce font-bold text-white leading-none text-6xl md:text-7xl lg:text-8xl">
        Stefanias<br />Cafè
      </h2>
      <p class="font-sauce text-white text-lg md:text-xl mt-4 opacity-90">
        Ein Stück Italia – mit Herz serviert.
      </p>
      <a
        href="#menu"
        class="mt-6 inline-block bg-white text-dark font-sauce font-bold text-base px-8 py-3 self-start hover:bg-cream transition-colors duration-200"
      >
        Menüübersicht
      </a>
    </div>
  </div>
</section>
