---
const base = import.meta.env.BASE_URL;
---
<section id="hero" class="hero">
  <div class="hero-bg">
    <img src={`${base}img/Media_caprese.png`} alt="" />
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Stefanias<br />Cafè</h1>
    <p>Ein Stück Italia – mit Herz serviert.</p>
    <a href="#menu" class="hero-btn">See our menu →</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--dark);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 10, 3, 0.62);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--text-light);
    padding: 2rem;
  }

  h1 {
    font-family: var(--font-script);
    font-size: clamp(3.5rem, 10vw, 6.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: #f5e8d0;
    margin-bottom: 0.8rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }

  p {
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: #e8d8c0;
    margin-bottom: 2rem;
  }

  .hero-btn {
    display: inline-block;
    background: rgba(245, 232, 208, 0.15);
    border: 1px solid rgba(245, 232, 208, 0.5);
    color: #f5e8d0;
    padding: 0.7rem 1.8rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    border-radius: 2px;
    transition: background 0.2s, border-color 0.2s;
  }

  .hero-btn:hover {
    background: rgba(245, 232, 208, 0.25);
    border-color: rgba(245, 232, 208, 0.8);
  }
</style>
