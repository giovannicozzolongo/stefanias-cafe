---
---
<section class="hero" id="hero">
  <div class="hero-left">
    <div class="hero-left-inner">
      <p class="hero-eyebrow">Ein Stück Italia — mitten in Erlangen</p>
      <h1 class="hero-title">Stefanias<br/>Cafè</h1>
      <p class="hero-sub">Hausgemachte Küche, Herz und Gastfreundschaft.</p>
      <a href="#menu" class="btn btn-outline-white hero-btn">See our menu &rarr;</a>
    </div>
  </div>
  <div class="hero-right">
    <img src="/stefanias-cafe/img/hero-bg.png" alt="Pasta artigianale di Stefania's Cafè" />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  /* ── LEFT PANEL ─────────────────────────── */
  .hero-left {
    background: var(--c-dark);
    display: flex;
    align-items: center;
    padding-top: 70px; /* header height */
  }

  .hero-left-inner {
    padding: 4rem 3.5rem 4rem 3rem;
    max-width: 520px;
  }

  .hero-eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1.4rem;
  }

  .hero-title {
    font-family: var(--font-brand);
    font-size: clamp(3.8rem, 6vw, 6rem);
    color: #fff;
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 0.95rem;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
    line-height: 1.7;
  }

  .hero-btn {
    font-size: 0.78rem;
    padding: 0.8rem 1.8rem;
  }

  /* ── RIGHT PANEL ─────────────────────────── */
  .hero-right {
    overflow: hidden;
  }

  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── MOBILE ─────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-left {
      padding-top: 70px;
    }

    .hero-left-inner {
      padding: 3rem 1.5rem;
    }

    .hero-title { font-size: 3.2rem; }

    .hero-right {
      height: 55vw;
      min-height: 260px;
    }
  }
</style>
