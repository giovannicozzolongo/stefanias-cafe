---
const reviews = [
  {
    text: 'Bin sehr angetan. Sehr freundlich und einfühlsam. Die Karte überschaubar, aber so entsteht Qualität. Immer wieder gibt\'s kleine Beigaben (Salami Käse Oliven)... Hier kann man sich wohlfühlen und sich selbst und liebe Menschen vor allem mit dem Dessert verwöhnen.',
    author: 'Klaus Becker',
    rating: 5,
  },
  {
    text: 'Das beste Tiramisù nördlich der Alpen. Die Atmosphäre ist warm, die Bedienung herzlich und das Essen einfach großartig. Kommt man einmal, kommt man immer wieder.',
    author: 'Maria Hoffmann',
    rating: 5,
  },
  {
    text: 'Endlich ein echtes italienisches Café in Erlangen. Der Cappuccino ist perfekt, die Croissants frisch und das Team immer mit einem Lächeln. Absolut empfehlenswert.',
    author: 'Thomas Müller',
    rating: 5,
  },
];
---

<section class="bg-cream py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6 md:px-12">

    <h2 class="font-garet font-bold text-brown-dark text-4xl md:text-5xl mb-14">
      Kundenmeinungen
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map(review => (
        <div class="flex flex-col gap-4">
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: review.rating }).map(() => (
              <svg class="w-4 h-4 text-terracotta fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
            ))}
          </div>

          <p class="font-garet text-brown-dark text-base leading-relaxed flex-1">
            "{review.text}"
          </p>

          <p class="font-garet text-brown-mid text-sm mt-2">
            — {review.author}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
