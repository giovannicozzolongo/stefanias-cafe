---
const base = import.meta.env.BASE_URL;
---
<header>
  <div class="header-inner">
    <a href="#hero" class="logo">
      <img src={`${base}img/Logo_Stefanias_cafe.png`} alt="Stefania's Cafè" />
    </a>
    <nav>
      <a href="#about">Home</a>
      <a href="#about">About</a>
      <a href="#menu">Menu</a>
      <a href="#gallery">Gallery</a>
      <a href="#reservation" class="nav-btn">Reservation</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(28, 17, 8, 0.85);
    backdrop-filter: blur(4px);
    padding: 0.6rem 2rem;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo img {
    height: 52px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  nav a {
    color: var(--text-light);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  nav a:hover {
    opacity: 1;
  }

  .nav-btn {
    background: var(--accent) !important;
    color: white !important;
    padding: 0.4rem 1rem;
    border-radius: 3px;
    opacity: 1 !important;
    font-weight: 700 !important;
    font-size: 0.8rem !important;
    letter-spacing: 0.04em;
  }

  .nav-btn:hover {
    background: #b5722a !important;
  }
</style>
