---
---
<header class="header">
  <div class="header-inner container">
    <a href="#hero" class="logo">
      <img src="/stefanias-cafe/img/logo.png" alt="Stefania's Cafè" />
    </a>
    <nav class="nav" id="nav">
      <a href="#hero">Home</a>
      <a href="#about">About</a>
      <a href="#menu">Menù</a>
      <a href="#orari">Öffnungszeiten</a>
      <a href="#reservation" class="nav-cta">Reservation</a>
    </nav>
    <button class="burger" id="burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .logo img {
    height: 42px;
    width: auto;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav a {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.9);
    transition: color 0.15s;
  }

  .nav a:hover { color: #fff; }

  .nav-cta {
    background: var(--c-orange) !important;
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: 2px;
    font-weight: 700;
  }
  .nav-cta:hover { background: #b8521f !important; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .burger span { display: block; width: 22px; height: 2px; background: #fff; }

  @media (max-width: 768px) {
    .burger { display: flex; }
    .nav {
      display: none;
      position: fixed;
      top: 70px;
      inset: 70px 0 auto;
      background: rgba(20,20,20,0.97);
      flex-direction: column;
      padding: 1.5rem;
      gap: 1.25rem;
    }
    .nav.open { display: flex; }
    .nav a { font-size: 1rem; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const nav = document.getElementById('nav');
  burger?.addEventListener('click', () => nav?.classList.toggle('open'));
  nav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => nav?.classList.remove('open')));
</script>
