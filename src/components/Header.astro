---
---
<header class="header" id="header">
  <div class="header-inner container">
    <a href="#hero" class="logo">
      <img src="/stefanias-cafe/img/logo.png" alt="Stefania's Cafè" />
    </a>

    <button class="burger" id="burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="nav">
      <a href="#hero">Home</a>
      <a href="#menu">Menù</a>
      <a href="#fruehstueck">Frühstück</a>
      <a href="#kontakt">Kontakt</a>
      <a href="#reservation" class="nav-btn">Reservierung</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    background: var(--c-black);
    height: 56px;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo img {
    height: 38px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.92;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav a {
    color: rgba(255,255,255,0.85);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .nav a:hover { color: var(--c-cream); }

  .nav-btn {
    background: var(--c-accent) !important;
    color: white !important;
    padding: 0.45rem 1.1rem;
    font-size: 0.7rem !important;
  }

  .nav-btn:hover { background: #7a4f3c !important; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
  }

  @media (max-width: 720px) {
    .burger { display: flex; }

    .nav {
      display: none;
      position: fixed;
      top: 56px;
      inset: 56px 0 auto;
      background: var(--c-black);
      flex-direction: column;
      padding: 1.5rem;
      gap: 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .nav.open { display: flex; }
    .nav a { font-size: 0.9rem; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const nav    = document.getElementById('nav');
  burger?.addEventListener('click', () => nav?.classList.toggle('open'));
  nav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => nav.classList.remove('open')));
</script>
