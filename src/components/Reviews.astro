    color: var(--text-dark);
    margin-bottom: 2rem;
  }

  .review-card {
    background: var(--cream2);
    padding: 2rem;
    border-radius: 4px;
  }

  .review-text {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #4a2e12;
    font-weight: 300;
    margin-bottom: 1.2rem;
    text-align: left;
  }

  .stars {
    font-size: 1.3rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .reviewer {
