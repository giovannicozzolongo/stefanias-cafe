---
const colazione = [
  { name: "Italienisch", desc: "Cappuccino + Cornetto", price: "5,50" },
  { name: "Stefanias", desc: "Toast Schinken/Käse + Heißes Getränk", price: "9,00" },
  { name: "Deutsch", desc: "Brot, Käse, Salat, Gurken, Tomaten, Lachs, Spiegelei", price: "9,40" },
  { name: "Bauern", desc: "Brot, Speck, Butter, Gurken, Tomaten, Oliven, Müsli, Obst, Käse, Jogurt", price: "11,70" },
  { name: "Napoli", desc: "Heißes Getränk, O-Saft, Cornetto Vanille & Beeren", price: "10,20" },
  { name: "Süß", desc: "Crêpes mit Vanille-Creme", price: "7,50" },
  { name: "Fitness", desc: "Jogurt, Müsli, Obst", price: "6,50" },
];

const piatti = [
  { name: "Omelette", desc: "Schinken und Mozzarella oder Paprika und Mozzarella", price: "8,80" },
  { name: "Bruschetta", desc: "Hausgemacht mit frischen Tomaten und Basilikum", price: "7,50" },
  { name: "Gefüllte Nudeln", desc: "Mit hausgemachter Füllung der Saison", price: "12,50" },
  { name: "Pinsa", desc: "Schinken und Mozzarella, knusprig gebacken", price: "11,20" },
  { name: "Nudeln mit Lachs", desc: "Mit Sahne und Lachs — Neuheit!", price: "14,80", tag: "Neu" },
  { name: "Lasagna", desc: "Klassisch, hausgemacht", price: "13,50" },
];
---

<section class="menu" id="menu">
  <div class="container">
    <div class="menu-header">
      <p class="section-label">Speisekarte</p>
      <h2 class="section-title">Cosa mangiamo <em>oggi?</em></h2>
    </div>

    <div class="menu-photo">
      <img src="/img/menu-colazione.jpg" alt="Frühstück Menütafel" />
      <img src="/img/menu-piatti.jpg" alt="Speisekarte Menütafel" />
    </div>

    <div class="menu-grid">
      <div class="menu-col">
        <h3 class="menu-col-title">Frühstück</h3>
        <p class="menu-col-sub">Buona colazione!</p>
        <ul class="menu-list">
          {colazione.map(item => (
            <li class="menu-item">
              <div class="menu-item-info">
                <span class="menu-item-name">{item.name}</span>
                <span class="menu-item-desc">{item.desc}</span>
              </div>
              <span class="menu-item-price">{item.price} €</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="menu-col">
        <h3 class="menu-col-title">Speisekarte</h3>
        <p class="menu-col-sub">Piatti del giorno</p>
        <ul class="menu-list">
          {piatti.map(item => (
            <li class="menu-item">
              <div class="menu-item-info">
                <span class="menu-item-name">
                  {item.name}
                  {item.tag && <span class="tag">{item.tag}</span>}
                </span>
                <span class="menu-item-desc">{item.desc}</span>
              </div>
              <span class="menu-item-price">{item.price} €</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .menu {
    padding: var(--section-pad);
    background: var(--color-bg);
  }

  .menu-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .menu-photo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    border-radius: 2px;
    overflow: hidden;
  }

  .menu-photo img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center top;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .menu-col-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .menu-col-sub {
    font-size: 0.8rem;
    color: var(--color-secondary);
    letter-spacing: 0.05em;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .menu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .menu-item:last-child {
    border-bottom: none;
  }

  .menu-item-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .menu-item-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-secondary);
    color: white;
    padding: 0.15rem 0.4rem;
  }

  .menu-item-desc {
    font-size: 0.8rem;
    color: #9a7a75;
    line-height: 1.4;
  }

  .menu-item-price {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-secondary);
    white-space: nowrap;
    padding-top: 0.1rem;
  }

  @media (max-width: 768px) {
    .menu-photo {
      grid-template-columns: 1fr;
    }

    .menu-photo img {
      height: 220px;
    }

    .menu-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
