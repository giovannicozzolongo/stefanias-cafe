---
const fruhstuck = [
  { name: 'Italienisch (Capp.+Cross.)', desc: '', price: '5,50' },
  { name: 'Stefanias', desc: 'Toast Schinken / Käse + Heiße Getränk', price: '9,00' },
  { name: 'Deutsch', desc: 'Brot, Käse, Salat, Gurken, Tomaten, Lachs, Spiegelei', price: '9,40' },
  { name: 'Bauern', desc: 'Brot, Speck, Butter, Gurken, Tomaten, Oliven, Müsli, Obst, Käse, Jogurt', price: '11,70' },
  { name: 'Napoli', desc: 'Heiße Getränk, O-Saft, Cross. Vanille & Beeren', price: '10,20' },
  { name: 'Süß', desc: 'Crêpes mit Vanille Creme', price: '7,50' },
  { name: 'Fitness', desc: 'Jogurt, Müsli, Obst, Becher', price: '6,50' },
];

const speisekarte = [
  { name: 'Omelette Schinken und Mozzarella', desc: 'oder Paprika und Mozzarella', price: '8,80' },
  { name: 'Bruschetta', desc: '', price: '7,50' },
  { name: 'Gefüllte Nudeln', desc: '', price: '12,50' },
  { name: 'Pinsa Schinken und Mozzarella', desc: '', price: '11,20' },
  { name: 'Nudeln mit Sahne und Lachs', desc: '(Neuheit!)', price: '14,80' },
  { name: 'Lasagna', desc: '', price: '13,50' },
];
---
<section id="menu" class="menu">
  <div class="menu-inner">
    <div class="menu-col">
      <h2>Frühstück</h2>
      <ul>
        {fruhstuck.map(item => (
          <li>
            <div class="item-name">
              <span class="name">{item.name}</span>
              {item.desc && <span class="desc">{item.desc}</span>}
            </div>
            <span class="price">€{item.price}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="menu-col">
      <h2>Speisekarte</h2>
      <ul>
        {speisekarte.map(item => (
          <li>
            <div class="item-name">
              <span class="name">{item.name}</span>
              {item.desc && <span class="desc">{item.desc}</span>}
            </div>
            <span class="price">€{item.price}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .menu {
    background: var(--cream2);
    padding: 4rem 2rem;
  }

  .menu-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  h2 {
    font-family: var(--font-body);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #c4936a;
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(196, 147, 106, 0.3);
    font-size: 0.85rem;
  }

  .item-name {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .name {
    font-weight: 700;
    color: var(--text-dark);
  }

  .desc {
    font-size: 0.75rem;
    color: #7a5030;
    font-weight: 300;
  }

  .price {
    font-weight: 700;
    color: var(--brown);
    white-space: nowrap;
    font-size: 0.88rem;
  }
</style>
