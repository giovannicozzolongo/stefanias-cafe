---
const fruehstueck = [
  { name: "Italienisch", desc: "Cappuccino + Cornetto", price: "5,50" },
  { name: "Stefanias", desc: "Toast Schinken/Käse + Heißes Getränk", price: "9,00" },
  { name: "Deutsch", desc: "Brot, Käse, Salat, Gurken, Tomaten, Lachs, Spiegelei", price: "9,40" },
  { name: "Bauern", desc: "Brot, Speck, Butter, Gurken, Tomaten, Oliven, Müsli, Obst, Käse, Jogurt", price: "11,70" },
  { name: "Napoli", desc: "Heißes Getränk, O-Saft, Cornetto Vanille & Beeren", price: "10,20" },
  { name: "Süß", desc: "Crêpes mit Vanille-Creme", price: "7,50" },
  { name: "Fitness", desc: "Jogurt, Müsli, Obst", price: "6,50" },
];

const piatti = [
  { name: "Omelette", desc: "Schinken & Mozzarella oder Paprika & Mozzarella", price: "8,80" },
  { name: "Bruschetta", desc: "Hausgemacht mit frischen Tomaten & Basilikum", price: "7,50" },
  { name: "Gefüllte Nudeln", desc: "Mit hausgemachter Füllung der Saison", price: "12,50" },
  { name: "Pinsa", desc: "Schinken & Mozzarella, knusprig gebacken", price: "11,20" },
  { name: "Nudeln mit Lachs", desc: "Sahne & Lachs — Neuheit!", price: "14,80", new: true },
  { name: "Lasagna", desc: "Klassisch, selbst gemacht", price: "13,50" },
];
---
<section class="menu" id="menu">
  <div class="container">

    <div class="menu-header" id="fruehstueck">
      <p class="section-tag">Das Neapolitanische Frühstück in Deutschland</p>
      <h2 class="section-heading">Buona colazione!</h2>
      <p class="menu-sub">
        Frühstück wie in Neapel — mit deutschem Touch. Jede Bestellung wird frisch zubereitet.
      </p>
    </div>

    <div class="menu-grid">
      <div class="menu-col">
        <h3 class="col-title">Frühstück</h3>
        <ul class="menu-list">
          {fruehstueck.map(item => (
            <li class="menu-item">
              <div class="item-info">
                <span class="item-name">{item.name}</span>
                <span class="item-desc">{item.desc}</span>
              </div>
              <span class="item-price">{item.price} €</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="menu-col">
        <h3 class="col-title">Speisekarte</h3>
        <ul class="menu-list">
          {piatti.map(item => (
            <li class="menu-item">
              <div class="item-info">
                <span class="item-name">
                  {item.name}
                  {item.new && <span class="badge-new">Neu</span>}
                </span>
                <span class="item-desc">{item.desc}</span>
              </div>
              <span class="item-price">{item.price} €</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>
</section>

<style>
  .menu {
    background: var(--c-white);
    padding: var(--pad-section);
  }

  .menu-header {
    margin-bottom: 3rem;
  }

  .menu-sub {
    font-size: 0.875rem;
    color: var(--c-muted);
    margin-top: 0.5rem;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .col-title {
    font-family: var(--font-brand);
    font-size: 1.6rem;
    color: var(--c-text);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-item:last-child { border-bottom: none; }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .item-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge-new {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--c-accent);
    color: white;
    padding: 0.1rem 0.4rem;
  }

  .item-desc {
    font-size: 0.78rem;
    color: var(--c-muted);
    line-height: 1.5;
  }

  .item-price {
    font-family: var(--font-brand);
    font-size: 1.1rem;
    color: var(--c-accent);
    white-space: nowrap;
    padding-top: 0.1rem;
  }

  @media (max-width: 720px) {
    .menu-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
