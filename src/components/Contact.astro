<section class="contact" id="kontakt">
  <div class="contact-photo">
    <img src="/stefanias-cafe/img/menu-colazione.jpg" alt="Stefania's Cafè — Schiffstraße 12, Erlangen" />
  </div>
  <div class="contact-info">
    <p class="section-tag">Kontakt & Anfahrt</p>
    <h2 class="section-heading">Kommt vorbei.</h2>

    <ul class="contact-list">
      <li>
        <strong>Adresse</strong>
        <span>Schiffstraße 12<br/>91054 Erlangen, Deutschland</span>
      </li>
      <li>
        <strong>Telefon</strong>
        <a href="tel:+499131205868">+49 9131 205868</a>
      </li>
      <li>
        <strong>E-Mail</strong>
        <a href="mailto:m_stefy83@yahoo.it">m_stefy83@yahoo.it</a>
      </li>
      <li>
        <strong>Instagram</strong>
        <a href="https://instagram.com/stefanias_cafe" target="_blank" rel="noopener">@stefanias_cafe</a>
      </li>
    </ul>

    <a
      href="https://www.google.com/maps/search/Schiffstra%C3%9Fe+12+Erlangen"
      target="_blank"
      rel="noopener"
      class="btn btn-dark"
      style="margin-top: 2rem; display: inline-block"
    >
      In Google Maps öffnen
    </a>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
  }

  .contact-photo {
    overflow: hidden;
  }

  .contact-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.85);
  }

  .contact-info {
    background: var(--c-warm);
    padding: 5rem calc((100vw - var(--max-w)) / 2 + var(--pad-x)) 5rem 5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-list strong {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-accent);
  }

  .contact-list span,
  .contact-list a {
    font-size: 0.9rem;
    color: var(--c-text);
    line-height: 1.6;
  }

  .contact-list a:hover { color: var(--c-accent); }

  @media (max-width: 900px) {
    .contact { grid-template-columns: 1fr; }
    .contact-photo { height: 55vw; order: -1; }
    .contact-info { padding: 3rem 1.5rem; }
  }
</style>
