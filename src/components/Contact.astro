<section class="contact" id="kontakt">
  <div class="container">
    <h2 class="contact-heading">Komm uns besuchen.</h2>
    <div class="contact-grid">
      <div class="contact-col">
        <p class="contact-label">Address</p>
        <p class="contact-val">Schiffstraße 12<br/>91054 Erlangen, Germany</p>
      </div>
      <div class="contact-col">
        <p class="contact-label">Email Address</p>
        <a href="mailto:m_stefy83@yahoo.it" class="contact-val contact-link">m_stefy83@yahoo.it</a>
      </div>
      <div class="contact-col">
        <p class="contact-label">Phone Number</p>
        <a href="tel:+499131205868" class="contact-val contact-link">+49 9131 205868</a>
      </div>
    </div>
    <a
      href="https://www.google.com/maps/search/Schiffstra%C3%9Fe+12+Erlangen"
      target="_blank"
      rel="noopener"
      class="btn btn-dark maps-btn"
    >
      In Google Maps öffnen
    </a>
  </div>

  <div class="contact-photo">
    <img src="/stefanias-cafe/img/outdoor.png" alt="Stefania's Cafè — esterno" />
  </div>
</section>

<style>
  .contact {
    background: var(--c-cream);
    padding: 5rem 0;
    border-top: 1px solid var(--c-border);
  }

  .contact-heading {
    font-family: var(--font-brand);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--c-dark);
    margin-bottom: 2.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .contact-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-orange);
    margin-bottom: 0.4rem;
  }

  .contact-val {
    font-size: 0.95rem;
    color: var(--c-text);
    line-height: 1.6;
  }

  .contact-link { transition: color 0.15s; }
  .contact-link:hover { color: var(--c-orange); }

  .maps-btn { margin-top: 0.5rem; }

  .contact-photo {
    margin-top: 3rem;
    border-radius: 2px;
    overflow: hidden;
    max-height: 380px;
    width: 100%;
  }

  .contact-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 720px) {
    .contact-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
