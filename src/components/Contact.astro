---
const hours = [
  { day: 'Mo – Fr', time: '07:30 – 18:00' },
  { day: 'Samstag', time: '08:00 – 17:00' },
  { day: 'Sonntag', time: '09:00 – 15:00' },
];
---

<section id="contact" class="bg-cream pt-20 md:pt-28">
  <div class="max-w-6xl mx-auto px-6 md:px-12">

    <div class="grid md:grid-cols-2 gap-16 pb-20">

      <!-- Left: contact info + amenities -->
      <div>
        <h2 class="font-garet text-brown-mid text-4xl md:text-5xl font-normal mb-10">
          Komm uns besuchen.
        </h2>

        <div class="flex flex-col gap-2 mb-8 font-sauce text-brown-dark">
          <p class="text-lg font-bold">Stefanias Cafè</p>
          <p>Musterstraße 12</p>
          <p>91052 Erlangen</p>
          <a href="tel:+4991234567890" class="hover:text-terracotta transition-colors">+49 9123 456 789</a>
          <a href="mailto:info@stefanias-cafe.de" class="hover:text-terracotta transition-colors">info@stefanias-cafe.de</a>
        </div>

        <!-- Öffnungszeiten -->
        <h3 class="font-garet font-bold text-brown-dark text-xl mb-4">Öffnungszeiten</h3>
        <ul class="flex flex-col gap-2 mb-10">
          {hours.map(h => (
            <li class="flex justify-between font-sauce text-brown-dark text-base max-w-xs">
              <span>{h.day}</span>
              <span class="text-brown-mid">{h.time}</span>
            </li>
          ))}
        </ul>

        <!-- Amenities -->
        <ul class="flex flex-col gap-4">

          <!-- Barrierefrei -->
          <li class="flex items-center gap-3 font-garet text-dark text-base">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Testa -->
              <circle cx="12" cy="3.5" r="2" fill="#38261c"/>
              <!-- Corpo e sedia a rotelle -->
              <path d="M9 8h4l1.5 4H18v2h-4.5L12 10.5V8" fill="#38261c"/>
              <path d="M9 8v5l-2 3h2l1.5-2.5" fill="#38261c"/>
              <!-- Ruota grande -->
              <circle cx="10" cy="18" r="3" stroke="#38261c" stroke-width="1.5" fill="none"/>
              <!-- Ruota piccola -->
              <circle cx="16" cy="17" r="1.5" stroke="#38261c" stroke-width="1.5" fill="none"/>
            </svg>
            Barrierefrei
          </li>

          <!-- Free Wi-Fi -->
          <li class="flex items-center gap-3 font-garet text-dark text-base">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Arco grande -->
              <path d="M2.5 9.5C6.5 5.5 17.5 5.5 21.5 9.5" stroke="#38261c" stroke-width="1.8" stroke-linecap="round" fill="none"/>
              <!-- Arco medio -->
              <path d="M5.5 12.5C8 10 16 10 18.5 12.5" stroke="#38261c" stroke-width="1.8" stroke-linecap="round" fill="none"/>
              <!-- Arco piccolo -->
              <path d="M8.5 15.5C9.8 14.2 14.2 14.2 15.5 15.5" stroke="#38261c" stroke-width="1.8" stroke-linecap="round" fill="none"/>
              <!-- Punto -->
              <circle cx="12" cy="19" r="1.3" fill="#38261c"/>
            </svg>
            Free Wi-Fi
          </li>

          <!-- Haustierfreundlich -->
          <li class="flex items-center gap-3 font-garet text-dark text-base">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Zampa principale -->
              <ellipse cx="12" cy="15" rx="4" ry="3.5" fill="#38261c"/>
              <!-- Dito 1 -->
              <ellipse cx="7.5" cy="11.5" rx="1.6" ry="2.2" fill="#38261c"/>
              <!-- Dito 2 -->
              <ellipse cx="10.5" cy="9.5" rx="1.6" ry="2.2" fill="#38261c"/>
              <!-- Dito 3 -->
              <ellipse cx="13.5" cy="9.5" rx="1.6" ry="2.2" fill="#38261c"/>
              <!-- Dito 4 -->
              <ellipse cx="16.5" cy="11.5" rx="1.6" ry="2.2" fill="#38261c"/>
            </svg>
            Haustierfreundlich
          </li>

        </ul>
      </div>

      <!-- Right: social + map placeholder -->
      <div>
        <h3 class="font-garet text-brown-mid text-xl font-normal mb-6">
          Folge uns auf Social Media
        </h3>
        <ul class="flex gap-4 mb-10">

          <!-- Instagram -->
          <li>
            <a href="#" aria-label="Instagram" class="flex items-center justify-center w-10 h-10 rounded-full border border-brown-dark text-brown-dark hover:bg-brown-dark hover:text-white transition-colors duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </a>
          </li>

          <!-- Facebook -->
          <li>
            <a href="#" aria-label="Facebook" class="flex items-center justify-center w-10 h-10 rounded-full border border-brown-dark text-brown-dark hover:bg-brown-dark hover:text-white transition-colors duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M17 2h-3a5 5 0 0 0-5 5v3H6v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3V2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </a>
          </li>

          <!-- Google Maps -->
          <li>
            <a href="#" aria-label="Google Maps" class="flex items-center justify-center w-10 h-10 rounded-full border border-brown-dark text-brown-dark hover:bg-brown-dark hover:text-white transition-colors duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.8" fill="none"/>
                <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
              </svg>
            </a>
          </li>

        </ul>

        <!-- Map placeholder -->
        <div class="w-full aspect-video bg-[#f5ede3] flex flex-col items-center justify-center gap-3 rounded-sm">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#38261c" opacity="0.25"/>
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="#38261c" stroke-width="1.5" fill="none"/>
            <circle cx="12" cy="9" r="2.5" stroke="#38261c" stroke-width="1.5" fill="none"/>
          </svg>
          <p class="font-garet text-brown-mid text-sm tracking-wide">Musterstraße 12, Erlangen</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Footer bar -->
  <footer class="bg-dark py-6 px-6 md:px-12">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sauce text-white text-sm opacity-70">
        © 2026 Stefanias Cafè · Erlangen
      </p>
      <p class="font-sauce text-white text-sm opacity-70">
        Ein Stück Italia – mit Herz serviert.
      </p>
    </div>
  </footer>

  <!-- Striscia bandiera italiana -->
  <div class="flex w-full h-4">
    <div class="flex-1 bg-[#009246]"></div>
    <div class="flex-1 bg-white"></div>
    <div class="flex-1 bg-[#ce2b37]"></div>
  </div>
</section>
