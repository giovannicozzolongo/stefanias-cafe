---
const features = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
    title: "Reservierung",
    desc: "Reserviert euren Tisch direkt online oder per Telefon. Wir freuen uns auf euch.",
    link: "#reservation",
    cta: "Jetzt reservieren",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>`,
    title: "Unsere Speisekarte",
    desc: "Frühstück, Mittagessen und Aperitivo. Alles frisch, alles hausgemacht — nach neapolitanischer Tradition.",
    link: "#menu",
    cta: "Speisekarte ansehen",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: "Öffnungszeiten",
    desc: "Di–Fr: 09–17 Uhr · Sa–So: 09–18 Uhr · Montag geschlossen. Schiffstraße 12, Erlangen.",
    link: "#orari",
    cta: "Auf Karte anzeigen",
  },
];
---
<section class="features">
  <div class="container features-inner">
    <div class="features-intro">
      <p>
        Stefanias Cafè entstand aus dem Traum, die Kultur meiner Stadt Neapel nach Deutschland zu bringen.
        Vom Kaffee bis zu den typischen Süßspeisen, sowie Wein und Aperitive. Das Lokal bietet ein
        gemütliches Ambiente und jedes kleinste Detail ist gepflegt — so wie unser Menü.
        Wir setzen auf Einfachheit und Originalität, deshalb findet ihr bei uns immer frische,
        selbst gemachte Speisen.
      </p>
    </div>
    <div class="features-grid">
      {features.map(f => (
        <div class="feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
          <a href={f.link} class="feature-link">{f.cta} →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--c-white);
    padding: 4rem var(--pad-x);
  }

  .features-inner { max-width: var(--max-w); margin: 0 auto; }

  .features-intro {
    max-width: 680px;
    margin-bottom: 3rem;
  }

  .features-intro p {
    font-size: 0.95rem;
    color: var(--c-muted);
    line-height: 1.8;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    border: 1px solid var(--c-border);
    padding: 2rem 1.75rem;
  }

  .feature-icon {
    color: var(--c-accent);
    margin-bottom: 1.25rem;
  }

  .feature-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-black);
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-size: 0.85rem;
    color: var(--c-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .feature-link {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-accent);
    transition: color 0.15s;
  }

  .feature-link:hover { color: var(--c-black); }

  @media (max-width: 720px) {
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
