---
const base = import.meta.env.BASE_URL;
const features = [
  {
    img: 'Bg_colazione.png',
    title: 'Büro-Frühstück',
    sub: '& frische Gebäckkleiden',
  },
  {
    img: 'Media_lasagna.png',
    title: 'Mittagspause',
    sub: '& italienischer Komfort',
  },
  {
    img: 'Media_pastiera.png',
    title: 'Nachmittags-Leckerl',
    sub: '& süße Auszeit',
  },
];
---
<section class="features">
  <div class="features-inner">
    <h2>Wir sind kein gewöhnliches Kaffeehaus.<br />Entdecke, was uns auszeichnet.</h2>
    <div class="cards">
      {features.map(f => (
        <div class="card">
          <div class="card-img">
            <img src={`${base}img/${f.img}`} alt={f.title} />
          </div>
          <div class="card-text">
            <strong>{f.title}</strong>
            <span>{f.sub}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--cream);
    padding: 3.5rem 2rem;
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.3;
    margin-bottom: 2rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .card {
    border-radius: 4px;
    overflow: hidden;
  }

  .card-img {
    height: 200px;
    overflow: hidden;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card:hover .card-img img {
    transform: scale(1.03);
  }

  .card-text {
    background: var(--cream2);
    padding: 0.7rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .card-text strong {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-dark);
  }

  .card-text span {
    font-size: 0.78rem;
    color: #7a5030;
    font-weight: 300;
  }
</style>
