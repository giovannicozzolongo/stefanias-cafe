---
const features = [
  {
    img: "/stefanias-cafe/img/feature-colazione.png",
    title: "Büro-Frühstück & frische Gebäckiden",
  },
  {
    img: "/stefanias-cafe/img/feature-pranzo.png",
    title: "Mittagspause & italienischer Komfort",
  },
  {
    img: "/stefanias-cafe/img/feature-aperitivo.png",
    title: "Nachmittags-Leckerli & süße Auszeit",
  },
];
---
<section class="features">
  <div class="container">
    <h2 class="features-heading">
      Wir sind kein gewöhnliches Kaffeehaus.<br/>
      Entdecke, was uns auszeichnet.
    </h2>
    <div class="features-grid">
      {features.map(f => (
        <div class="feature-card">
          <div class="feature-photo">
            <img src={f.img} alt={f.title} />
          </div>
          <p class="feature-title">{f.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--c-white);
    padding: 5rem 0;
  }

  .features-heading {
    font-family: var(--font-brand);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--c-dark);
    line-height: 1.3;
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card { display: flex; flex-direction: column; gap: 1rem; }

  .feature-photo {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 2px;
  }

  .feature-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .feature-card:hover .feature-photo img { transform: scale(1.04); }

  .feature-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--c-dark);
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
