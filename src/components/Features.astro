---
const cards = [
  {
    title: 'Büro-Frühstück\n& frische Gebäckideen',
    image: '/images/Bg_colazione.png',
    alt: 'Frühstück',
  },
  {
    title: 'Mittagspause\n& italienischer Komfort',
    image: '/images/Bg_fusilli.png',
    alt: 'Mittagspause',
  },
  {
    title: 'Nachmittags-Leckerli\n& süße Auszeit',
    image: '/images/Media_tiramisu.png',
    alt: 'Nachmittagssnack',
  },
];
---

<section id="about" class="bg-cream py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6 md:px-12">

    <p class="font-garet text-brown-mid text-2xl md:text-4xl lg:text-5xl leading-tight mb-16 max-w-3xl">
      Wir sind kein gewöhnliches Kaffeehaus.<br />
      Entdecke, was uns auszeichnet.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map(card => (
        <div class="flex flex-col">
          <div class="overflow-hidden aspect-[4/3]">
            <img
              src={card.image}
              alt={card.alt}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="pt-5 pb-4 border-b border-beige">
            <h3 class="font-sauce font-bold text-brown-dark text-xl leading-snug whitespace-pre-line">
              {card.title}
            </h3>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
