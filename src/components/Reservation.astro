---
---
<section id="reservation" class="reservation">
  <div class="reservation-inner">
    <div class="res-left">
      <h2>Reservation</h2>
      <div class="calendar">
        <div class="cal-header">
          <span>◀</span>
          <span>October 2020</span>
          <span>▶</span>
        </div>
        <div class="cal-days-header">
          <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
        <div class="cal-days">
          <span class="empty"></span>
          <span class="empty"></span>
          <span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
          <span>6</span><span>7</span><span>8</span><span>9</span><span>10</span><span>11</span><span>12</span>
          <span>13</span><span>14</span><span>15</span><span>16</span><span>17</span><span>18</span><span>19</span>
          <span>20</span><span>21</span><span>22</span><span>23</span><span>24</span><span>25</span><span>26</span>
          <span class="active">27</span><span>28</span><span>29</span><span>30</span><span>31</span>
        </div>
        <div class="date-input">
          <span>31.10.2020</span>
          <span>11:00 AM</span>
        </div>
      </div>
    </div>
    <div class="res-right">
      <h3>Pick a time</h3>
      <div class="time-slots">
        <button class="slot">7:00 – 9:30 AM</button>
        <button class="slot">9:30 – 11:30 AM</button>
        <button class="slot active">11:00 – 1:00 PM</button>
        <button class="slot">1:00 – 3:00 PM</button>
        <button class="slot">3:00 – 5:30 PM</button>
      </div>
      <div class="res-actions">
        <button class="btn-back">Back</button>
        <button class="btn-book">Book Now</button>
      </div>
    </div>
  </div>
</section>

<style>
  .reservation {
    background: var(--cream);
    padding: 3rem 2rem;
    border-top: 1px solid #e8d5c0;
    border-bottom: 1px solid #e8d5c0;
  }

  .reservation-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .res-left h2 {
    font-family: var(--font-body);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1.2rem;
  }

  .calendar {
    background: #f5ede0;
    border-radius: 6px;
    overflow: hidden;
    font-size: 0.8rem;
  }

  .cal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.8rem;
    background: #eddfc8;
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--text-dark);
  }

  .cal-days-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    padding: 0.4rem 0.3rem 0.2rem;
    font-weight: 700;
    font-size: 0.7rem;
    color: #8b6040;
    gap: 2px;
  }

  .cal-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    padding: 0.2rem 0.3rem 0.5rem;
    gap: 2px;
  }

  .cal-days span {
    padding: 0.25rem;
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--text-dark);
  }

  .cal-days span:hover {
    background: #ddc9a8;
  }

  .cal-days span.active {
    background: var(--brown);
    color: white;
    border-radius: 50%;
  }

  .date-input {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0.3rem 0.6rem 0.6rem;
    background: #eddfc8;
    padding: 0.4rem 0.7rem;
    border-radius: 3px;
    font-size: 0.78rem;
    color: var(--text-dark);
  }

  .res-right h3 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .time-slots {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.2rem;
  }

  .slot {
    background: #f0e4d0;
    border: none;
    padding: 0.55rem 1rem;
    text-align: left;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--text-dark);
    cursor: pointer;
    border-radius: 3px;
    transition: background 0.15s;
  }

  .slot:hover {
    background: #ddc9a8;
  }

  .slot.active {
    background: var(--brown);
    color: white;
  }

  .res-actions {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .btn-back {
    background: transparent;
    border: 1px solid #c4936a;
    color: var(--brown);
    padding: 0.5rem 1.4rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    cursor: pointer;
    border-radius: 3px;
  }

  .btn-book {
    background: var(--brown);
    border: none;
    color: white;
    padding: 0.5rem 1.4rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    border-radius: 3px;
    transition: background 0.15s;
  }

  .btn-book:hover {
    background: #7a4f2a;
  }
</style>
