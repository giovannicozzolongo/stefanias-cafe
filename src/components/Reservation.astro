---
---

<section class="reservation" id="reservation">
  <div class="reservation-bg">
    <img src="/img/menu-colazione.jpg" alt="" aria-hidden="true" />
    <div class="reservation-overlay"></div>
  </div>
  <div class="container reservation-inner">
    <div class="reservation-text">
      <p class="section-label" style="color: rgba(255,244,240,0.7)">Reservierung</p>
      <h2 class="section-title" style="color: white">
        Tisch reservieren.<br />
        <em style="color: #f0c9b4">Wir freuen uns auf euch.</em>
      </h2>
      <p style="color: rgba(255,244,240,0.8); margin-bottom: 1.5rem; line-height: 1.7;">
        Schickt uns einfach eine Anfrage — wir melden uns so schnell wie möglich.
        Per telefono: <a href="tel:+499131205868" style="color: #f0c9b4; font-weight: 600;">+49 9131 205868</a>
      </p>
    </div>

    <form class="reservation-form" id="reservation-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label for="r-name">Name</label>
          <input type="text" id="r-name" name="name" placeholder="Ihr Name" required />
        </div>
        <div class="form-group">
          <label for="r-phone">Telefon</label>
          <input type="tel" id="r-phone" name="phone" placeholder="+49 ..." required />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="r-date">Datum</label>
          <input type="date" id="r-date" name="date" required />
        </div>
        <div class="form-group">
          <label for="r-time">Uhrzeit</label>
          <input type="time" id="r-time" name="time" min="09:00" max="18:00" required />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="r-guests">Gäste</label>
          <select id="r-guests" name="guests" required>
            <option value="">Anzahl wählen</option>
            {[1,2,3,4,5,6,7,8].map(n => (
              <option value={n}>{n} {n === 1 ? 'Person' : 'Personen'}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="r-email">E-Mail</label>
          <input type="email" id="r-email" name="email" placeholder="ihre@email.de" />
        </div>
      </div>
      <div class="form-group">
        <label for="r-message">Nachricht (optional)</label>
        <textarea id="r-message" name="message" rows="3" placeholder="Allergien, Anlässe, Besonderes..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width: 100%">
        Reservierung anfragen
      </button>
      <p class="form-note">
        Die Anfrage wird per E-Mail an Stefania weitergeleitet.
        Eine Bestätigung folgt telefonisch oder per E-Mail.
      </p>
    </form>
  </div>
</section>

<style>
  .reservation {
    position: relative;
    padding: var(--section-pad);
  }

  .reservation-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .reservation-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(2px) brightness(0.4);
    transform: scale(1.05);
  }

  .reservation-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 15, 14, 0.6);
  }

  .reservation-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }

  .reservation-form {
    background: white;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  input, select, textarea {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-light);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--color-secondary);
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-note {
    font-size: 0.75rem;
    color: #9a7a75;
    text-align: center;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .reservation-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .reservation-form {
      padding: 1.5rem;
    }
  }
</style>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const body = `Reservierungsanfrage:\n\nName: ${data.get('name')}\nTelefon: ${data.get('phone')}\nE-Mail: ${data.get('email')}\nDatum: ${data.get('date')}\nUhrzeit: ${data.get('time')}\nGäste: ${data.get('guests')}\nNachricht: ${data.get('message')}`;
    window.location.href = `mailto:m_stefy83@yahoo.it?subject=Reservierungsanfrage Stefanias Cafè&body=${encodeURIComponent(body)}`;
  });
</script>
