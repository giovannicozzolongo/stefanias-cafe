---
---
<section class="reservation" id="reservation">
  <div class="res-inner container">
    <div class="res-text">
      <p class="section-tag">Reservierung</p>
      <h2 class="section-heading" style="color: var(--c-cream)">Einen Tisch<br/>reservieren</h2>
      <p class="res-sub">
        Schickt uns eure Anfrage — wir melden uns schnellstmöglich zurück.
        Telefonisch erreichbar unter
        <a href="tel:+499131205868">+49 9131 205868</a>.
      </p>
    </div>

    <form class="res-form" id="res-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label for="r-name">Name</label>
          <input type="text" id="r-name" name="name" placeholder="Ihr Name" required />
        </div>
        <div class="form-group">
          <label for="r-phone">Telefon</label>
          <input type="tel" id="r-phone" name="phone" placeholder="+49 ..." />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="r-date">Datum</label>
          <input type="date" id="r-date" name="date" required />
        </div>
        <div class="form-group">
          <label for="r-time">Uhrzeit</label>
          <input type="time" id="r-time" name="time" min="09:00" max="18:00" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="r-guests">Gäste</label>
          <select id="r-guests" name="guests">
            <option value="">Anzahl wählen</option>
            {[1,2,3,4,5,6,7,8].map(n => (
              <option value={n}>{n} {n === 1 ? 'Person' : 'Personen'}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="r-email">E-Mail</label>
          <input type="email" id="r-email" name="email" placeholder="ihre@email.de" />
        </div>
      </div>
      <button type="submit" class="btn btn-cream" style="width:100%">
        Reservierungsanfrage senden
      </button>
    </form>
  </div>
</section>

<style>
  .reservation {
    background: var(--c-brown);
    padding: var(--pad-section);
  }

  .res-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 5rem;
    align-items: start;
  }

  .res-sub {
    font-size: 0.9rem;
    color: rgba(245,236,215,0.7);
    line-height: 1.75;
    margin-top: 1.25rem;
  }

  .res-sub a {
    color: var(--c-cream);
    font-weight: 700;
  }

  .res-form {
    background: rgba(0,0,0,0.25);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,236,215,0.6);
  }

  input, select {
    font-family: var(--font-body);
    font-size: 0.875rem;
    padding: 0.65rem 0.875rem;
    border: 1px solid rgba(245,236,215,0.2);
    background: rgba(0,0,0,0.2);
    color: var(--c-cream);
    outline: none;
    width: 100%;
  }

  input::placeholder { color: rgba(245,236,215,0.35); }

  input:focus, select:focus {
    border-color: var(--c-accent);
  }

  select option { background: var(--c-brown); color: var(--c-cream); }

  @media (max-width: 900px) {
    .res-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
    .res-form { padding: 1.5rem; }
  }
</style>

<script>
  document.getElementById('res-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const d = new FormData(e.target as HTMLFormElement);
    const body = `Name: ${d.get('name')}\nTel: ${d.get('phone')}\nEmail: ${d.get('email')}\nDatum: ${d.get('date')}\nUhrzeit: ${d.get('time')}\nGäste: ${d.get('guests')}`;
    window.location.href = `mailto:m_stefy83@yahoo.it?subject=Reservierungsanfrage&body=${encodeURIComponent(body)}`;
  });
</script>
