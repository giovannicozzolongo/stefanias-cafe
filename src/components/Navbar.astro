---
const links = [
  { label: 'Home', href: '#home' },
  { label: 'About', href: '#about' },
  { label: 'Menu', href: '#menu' },
  { label: 'Gallery', href: '#gallery' },
  { label: 'Reservation', href: '#reservation' },
];
---

<nav class="flex items-center justify-between px-8 py-3 w-full">
  <a href="#home" class="font-sauce font-bold text-white text-xl tracking-wide">
    Stefanias Cafè
  </a>
  <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class="font-garet text-white text-sm tracking-widest uppercase hover:text-beige transition-colors duration-200"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    class="md:hidden flex flex-col gap-1.5 p-2"
    aria-label="Apri menu"
  >
    <span class="block w-6 h-0.5 bg-white"></span>
    <span class="block w-6 h-0.5 bg-white"></span>
    <span class="block w-6 h-0.5 bg-white"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="hidden md:hidden absolute top-full left-0 w-full bg-dark z-50 px-8 py-6"
>
  <ul class="flex flex-col gap-5 list-none m-0 p-0">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class="font-garet text-white text-sm tracking-widest uppercase hover:text-beige transition-colors duration-200"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
