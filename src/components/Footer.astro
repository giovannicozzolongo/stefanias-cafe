---
const base = import.meta.env.BASE_URL;
---
<footer>
  <div class="footer-cta">
    <h2>Komm uns besuchen.</h2>
    <p>FOLGE UNS AUF SOCIAL MEDIA</p>
    <div class="social">
      <a href="#" aria-label="Facebook">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
      </a>
      <a href="#" aria-label="Instagram">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    </div>
  </div>
  <div class="footer-info">
    <div class="contact-item">
      <span class="icon">📍</span>
      <div>
        <strong>ADDRESS</strong>
        <p>Schlossallee 12, 91054 Erlangen, Germany</p>
      </div>
    </div>
    <div class="contact-item">
      <span class="icon">✉</span>
      <div>
        <strong>EMAIL ADDRESS</strong>
        <p>info@stefanias-cafe.de</p>
      </div>
    </div>
    <div class="contact-item">
      <span class="icon">📞</span>
      <div>
        <strong>PHONE NUMBER</strong>
        <p>+49 (0) 9131 XXX XXX</p>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2024 Stefania's Cafè · <a href="#">Impressum</a> · <a href="#">Datenschutz</a></p>
  </div>
</footer>

<style>
  footer {
    background: var(--dark);
    color: var(--text-light);
  }

  .footer-cta {
    padding: 3rem 2rem 2rem;
    text-align: center;
    border-bottom: 1px solid rgba(245, 232, 208, 0.1);
  }

  .footer-cta h2 {
    font-family: var(--font-script);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: #f0e0c8;
    margin-bottom: 1rem;
  }

  .footer-cta p {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: #a09080;
    margin-bottom: 1rem;
  }

  .social {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .social a {
    color: #d8c8b0;
    transition: color 0.2s;
  }

  .social a:hover {
    color: var(--accent);
  }

  .footer-info {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .contact-item {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
  }

  .icon {
    font-size: 1.1rem;
    margin-top: 0.1rem;
    opacity: 0.7;
  }

  .contact-item strong {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: #a09080;
    margin-bottom: 0.3rem;
  }

  .contact-item p {
    font-size: 0.82rem;
    color: #d8c8b0;
    font-weight: 300;
    line-height: 1.5;
  }

  .footer-bottom {
    padding: 1rem 2rem;
    text-align: center;
    border-top: 1px solid rgba(245, 232, 208, 0.08);
  }

  .footer-bottom p {
    font-size: 0.72rem;
    color: #806050;
  }

  .footer-bottom a {
    color: #a09080;
    transition: color 0.15s;
  }

  .footer-bottom a:hover {
    color: var(--accent);
  }
</style>
