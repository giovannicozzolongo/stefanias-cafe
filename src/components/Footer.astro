---
const amenities = [
  { label: "Barrierefrei", icon: "♿" },
  { label: "Freies WLAN", icon: "📶" },
  { label: "Haustierfreundlich", icon: "🐾" },
];
---
<footer class="footer">
  <div class="container footer-inner">
    {amenities.map(a => (
      <div class="amenity">
        <span class="amenity-icon">{a.icon}</span>
        <span class="amenity-label">{a.label}</span>
      </div>
    ))}
  </div>
  <div class="footer-copy">
    <div class="container">
      <p>© 2026 Stefania's Cafè · Schiffstraße 12, 91054 Erlangen</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-dark);
    padding-top: 2.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    padding-bottom: 2rem;
    flex-wrap: wrap;
  }

  .amenity {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .amenity-icon {
    font-size: 1.6rem;
  }

  .amenity-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .footer-copy {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1rem 0;
  }

  .footer-copy p {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.2);
    text-align: center;
  }
</style>
