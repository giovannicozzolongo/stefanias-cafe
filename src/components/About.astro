---
---
<section class="about" id="about">
  <div class="about-inner container">
    <div class="about-text">
      <p class="section-tag">Chi siamo</p>
      <h2 class="section-heading">Neapels Wärme<br/>erwartet Sie bei Stefania!</h2>
      <p class="about-body">
        Willkommen bei Stefanias Cafè in Erlangen — italienischer Kaffee, frische Süßigkeiten und Aperitifs mit Neapel-Sonne!
      </p>
      <a href="#reservation" class="btn btn-orange about-btn">Tisch reservieren &rarr;</a>
    </div>
    <div class="about-photo">
      <img src="/stefanias-cafe/img/about-lasagna.png" alt="Lasagna di Stefania" />
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--c-white);
    padding: 5rem 0;
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text { max-width: 480px; }

  .about-body {
    font-size: 1rem;
    color: var(--c-muted);
    line-height: 1.85;
    margin-bottom: 2rem;
  }

  .about-photo {
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-text { max-width: 100%; }
    .about-photo { aspect-ratio: 16/9; }
  }
</style>
